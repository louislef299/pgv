{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "lightpanda": {
      "type": "local",
      "command": ["lightpanda", "mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "brew install *": "deny",
      "brew *": "ask",
      "rm *": "ask",
      "curl *": "ask"
    }
  }
}
